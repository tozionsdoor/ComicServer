# ── Python ──────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
build/
dist/
*.spec.bak

# ── 設定ファイル（パスワード・認証情報を含むため除外） ──────────
# サーバーtoken・Firebase api_key を含むため除外（クライアント側のFirebase設定は
# 公開前提の値なので google-services.json / firebase_options.dart はコミットする）
manga_server_config.json

# ── サムネイルキャッシュ（大量ファイル） ────────────────────
cache/

# ── Flutter / Dart ───────────────────────────────────────
comicserver_app/.dart_tool/
comicserver_app/.flutter-plugins
comicserver_app/.flutter-plugins-dependencies
comicserver_app/.metadata
comicserver_app/build/
comicserver_app/android/.gradle/
comicserver_app/android/.kotlin/
comicserver_app/android/local.properties
comicserver_app/android/key.properties
comicserver_app/ios/.symlinks/
comicserver_app/ios/Pods/
comicserver_app/ios/Flutter/Flutter.framework
comicserver_app/ios/Flutter/Flutter.podspec
comicserver_app/pubspec.lock
comicserver_app/**/*.g.dart
comicserver_app/**/*.freezed.dart

# ── PyInstaller ──────────────────────────────────────────
comicserver_app/__pycache__/
*.egg-info/

# ── ビルド生成物・配布バイナリ（NAS上に配置、gitには入れない） ──
app-release.apk
*.apk
*.aab
cloudflared.exe

# ── TLS 証明書（自動生成・秘密鍵） ─────────────────────────
server.crt
server.key

# ── Windows ──────────────────────────────────────────────
Thumbs.db
desktop.ini

# ── スクショ元データ（個人情報マスク前、非公開） ─────────────
docs/images/_unmasked_originals/

# ── ローカル開発ツールの設定・キャッシュ（環境依存） ─────────
.claude/
.firebase/
